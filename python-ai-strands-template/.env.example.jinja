# =============================================================================
# {{project_slug}} — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ── AWS Credentials ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# ── LLM Provider (bedrock | aicafe) ──────────────────────────────────────────
LLM_PROVIDER=bedrock

# ── Bedrock Model ────────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# ── AICafe ───────────────────────────────────────────────────────────────────
AICAFE_API_KEY=
AICAFE_BASE_URL=https://aicafe.hcl.com/AICafeService/api/v1/subscription/openai
AICAFE_DEPLOYMENT_NAME=gpt-4.1
AICAFE_API_VERSION=2024-12-01-preview
AICAFE_EMBEDDINGS_DEPLOYMENT_NAME=ADA
AICAFE_EMBEDDINGS_API_VERSION=2023-05-15

# ── Common LLM Parameters ───────────────────────────────────────────────────
AGENT_TEMPERATURE=0.1
AGENT_TOP_P=0.9
AGENT_MAX_TOKENS=4096

# ── Session Management ────────────────────────────────────────────────────────
SESSION_BACKEND=file
SESSION_DIR=.sessions
