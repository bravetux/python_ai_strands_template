"""Example tools demonstrating the Strands @tool decorator pattern."""

import logging

import httpx
from strands import tool

from {{project_slug_underscore}}.config.settings import settings

logger = logging.getLogger(__name__)


@tool
def greet(name: str) -> str:
    """Greet a person by name.

    Args:
        name: The name of the person to greet.

    Returns:
        A greeting message.
    """
    return f"Hello, {name}! Welcome to {{project_slug}}."


@tool
def add_numbers(a: float, b: float) -> dict:
    """Add two numbers together.

    Args:
        a: The first number.
        b: The second number.

    Returns:
        A dict with the inputs, result, and operation performed.
    """
    try:
        result = a + b
        return {"a": a, "b": b, "result": result, "operation": "addition"}
    except Exception as e:
        return {"error": str(e)}


@tool
def get_embedding(text: str) -> dict:
    """Generate an embedding vector for the given text using AICafe embeddings API.

    Args:
        text: The text to generate an embedding for.

    Returns:
        A dict with the input text and embedding vector, or an error message.
    """
    url = (
        f"{settings.aicafe_base_url}/deployments/"
        f"{settings.aicafe_embeddings_deployment_name}/embeddings"
    )
    headers = {
        "api-key": settings.aicafe_api_key,
        "Content-Type": "application/json",
    }
    params = {"api-version": settings.aicafe_embeddings_api_version}
    payload = {"input": [text]}

    try:
        response = httpx.post(url, headers=headers, params=params, json=payload, timeout=30)
        response.raise_for_status()
        data = response.json()
        embedding = data["data"][0]["embedding"]
        return {
            "text": text,
            "embedding": embedding,
            "dimensions": len(embedding),
        }
    except Exception as e:
        logger.error("AICafe embedding request failed: %s", e)
        return {"error": str(e)}
