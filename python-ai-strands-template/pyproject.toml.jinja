[project]
name = "{{project_slug}}"
description = "{{project_description}}"
readme = { file = "README.md", content-type = "text/markdown" }
requires-python = "{{python_version}}"
dependencies = [
    "strands-agents>=0.1",
    "strands-agents-tools>=0.1",
    "streamlit>=1.40",
    "boto3>=1.35",
"pydantic>=2.7",
    "pydantic-settings>=2.0",
    "python-dotenv>=1.0",
]
version = "0.0.0"

[dependency-groups]
dev = [
    "commitizen==4.13.0",
    "pre-commit==4.5.1",
    "pytest==9.0.2",
    "pytest-cov==7.0.0",
    "pytest-mock==3.14.0",
    "ruff==0.14.14",
    "mike==2.1.3",
    "mkdocs-autorefs==1.4.3",
    "mkdocs-gen-files==0.6.0",
    "mkdocs-literate-nav==0.6.2",
    "mkdocs-material==9.7.1",
    "mkdocs-section-index==0.3.10",
    "mkdocstrings[python]==1.0.2",
    "pymdown-extensions==10.20.1",
]

[tool.uv]
required-version = ">=0.8.0"
native-tls = true

[build-system]
requires = ["uv_build>=0.8.11,<0.9.0"]
build-backend = "uv_build"

[project.urls]
"Homepage" = "https://github.com/{{github_username}}/{{project_slug}}"
"Source" = "https://github.com/{{github_username}}/{{project_slug}}"

[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = [
    "--cov=src/",
    "--cov-report=xml",
    "--cov-report=term-missing",
    "--junitxml=report.xml",
]
pythonpath = [
    ".",
    "src",
]

[tool.ruff]
respect-gitignore = true

[tool.commitizen]
version_provider = "uv"
